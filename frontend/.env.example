# WeatherNow Frontend - Environment Variables Template
# Copy this file to .env.local for local development, or set this on your hosting provider (Vercel/Netlify)

# The base URL of your deployed Node.js backend API (no trailing slash)
# Example: https://weathernow-backend.onrender.com
# For local development, leave this blank or unset to fallback to the Vite local proxy configuration.
VITE_API_URL=
